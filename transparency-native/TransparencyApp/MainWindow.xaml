<Window x:Class="TransparencyApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Transparency - Native Device Monitor" Height="800" Width="1200"
        Background="#0A1020" Foreground="#E0E0E0">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#050A15" BorderBrush="#1AFFFFFF" BorderThickness="0,0,1,0">
            <StackPanel Margin="20">
                <TextBlock Text="🛡️ Transparency" FontSize="24" FontWeight="Bold" Foreground="#00D4FF" Margin="0,0,0,40"/>
                
                <Button Name="NavDashboard" Content="📊 Dashboard" Click="Nav_Click" Tag="Dashboard" Style="{StaticResource NavButtonStyle}"/>
                <Button Name="NavAnomalies" Content="🚨 Anomalies" Click="Nav_Click" Tag="Anomalies" Style="{StaticResource NavButtonStyle}"/>
                <Button Name="NavLedger" Content="📜 Data Ledger" Click="Nav_Click" Tag="Ledger" Style="{StaticResource NavButtonStyle}"/>
                <Button Name="NavSettings" Content="⚙️ Settings" Click="Nav_Click" Tag="Settings" Style="{StaticResource NavButtonStyle}"/>
                
                <StackPanel VerticalAlignment="Bottom" Margin="0,200,0,0">
                    <TextBlock Text="v1.0.0-native" Foreground="#666" FontSize="12"/>
                    <TextBlock Text="Status: Online" Foreground="#00CC00" FontSize="12"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Content Area -->
        <Grid Grid.Column="1" Margin="40">
            <!-- Dashboard View -->
            <StackPanel Name="ViewDashboard" Visibility="Visible">
                <DockPanel LastChildFill="False" Margin="0,0,0,30">
                    <TextBlock Text="Network Dashboard" FontSize="32" FontWeight="Bold" Foreground="#00D4FF"/>
                    <Button Content="🔍 Start Network Scan" Click="Scan_Click" DockPanel.Dock="Right" Padding="20,10" Background="#00D4FF" Foreground="#000" BorderThickness="0" FontWeight="Bold"/>
                </DockPanel>

                <UniformGrid Columns="3" Margin="0,0,0,40">
                    <Border Background="#10FFFFFF" CornerRadius="10" Padding="20" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="TOTAL DEVICES" Foreground="#AAA" FontSize="12"/>
                            <TextBlock Name="TxtTotalDevices" Text="0" FontSize="36" FontWeight="Bold" Foreground="#00D4FF"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#10FFFFFF" CornerRadius="10" Padding="20" Margin="5,0,5,0">
                        <StackPanel>
                            <TextBlock Text="ACTIVE THREATS" Foreground="#AAA" FontSize="12"/>
                            <TextBlock Name="TxtActiveThreats" Text="0" FontSize="36" FontWeight="Bold" Foreground="#FFAA00"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#10FFFFFF" CornerRadius="10" Padding="20" Margin="10,0,0,0">
                        <StackPanel>
                            <TextBlock Text="CLOUD SYNCS" Foreground="#AAA" FontSize="12"/>
                            <TextBlock Name="TxtCloudSyncs" Text="0" FontSize="36" FontWeight="Bold" Foreground="#0099CC"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <TextBlock Text="Device List" FontSize="18" Foreground="#AAA" Margin="0,0,0,10"/>
                <DataGrid Name="DeviceGrid" AutoGenerateColumns="False" Background="Transparent" BorderThickness="0" Foreground="#E0E0E0" RowBackground="#050A15" AlternatingRowBackground="#0A1020" GridLinesVisibility="None" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="IP Address" Binding="{Binding IpAddress}" Width="*"/>
                        <DataGridTextColumn Header="MAC Address" Binding="{Binding MacAddress}" Width="*"/>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                        <DataGridTemplateColumn Header="Actions" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="🛡️ Enrich" Click="Enrich_Click" Background="#20FFFFFF" Foreground="#00D4FF" BorderThickness="1" BorderBrush="#00D4FF" Padding="5,2"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>

            <!-- Other views omitted for brevity in template, implemented in full logic -->
            <StackPanel Name="ViewAnomalies" Visibility="Collapsed">
                <TextBlock Text="Security Anomalies" FontSize="32" FontWeight="Bold" Foreground="#00D4FF" Margin="0,0,0,30"/>
                <ItemsControl Name="AnomaliesList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#20FF4444" BorderBrush="#40FF4444" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="#FF4444" Width="40" Height="40" CornerRadius="20" Margin="0,0,15,0">
                                        <TextBlock Text="!" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Type}" FontWeight="Bold" FontSize="16"/>
                                        <TextBlock Text="{Binding Description}" Foreground="#AAA"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <StackPanel Name="ViewLedger" Visibility="Collapsed">
                <TextBlock Text="Data Ledger" FontSize="32" FontWeight="Bold" Foreground="#00D4FF" Margin="0,0,0,30"/>
                <ListBox Name="LedgerList" Background="#000" Foreground="#00FF00" FontFamily="Consolas" BorderThickness="1" BorderBrush="#333" Height="400"/>
            </StackPanel>
        </Grid>

        <!-- Loading Overlay -->
        <Border Name="LoadingOverlay" Grid.ColumnSpan="2" Background="#CC000000" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Scanning Network..." FontSize="24" Foreground="#00D4FF"/>
            </StackPanel>
        </Border>
    </Grid>

    <Window.Resources>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAA"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1AFFFFFF"/>
                    <Setter Property="Foreground" Value="#00D4FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
</Window>
