<Window x:Class="TransparencyApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Transparency - Network Intelligence"
        Height="900" Width="1380" MinHeight="760" MinWidth="1120"
        Background="#05070A" Foreground="#ECF0FA"
        FontFamily="Segoe UI Variable, Segoe UI"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <LinearGradientBrush x:Key="BgRoot" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#05070A" Offset="0"/>
            <GradientStop Color="#081224" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="Glass" Color="#77131D2E"/>
        <SolidColorBrush x:Key="GlassStrong" Color="#A018243A"/>
        <SolidColorBrush x:Key="Border" Color="#5A4E658F"/>
        <SolidColorBrush x:Key="Accent" Color="#3D7FFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#A8B6CE"/>
        <SolidColorBrush x:Key="TextMuted" Color="#6A7C9E"/>
        <SolidColorBrush x:Key="Danger" Color="#FF607A"/>
        <SolidColorBrush x:Key="Success" Color="#2FD191"/>
        <DropShadowEffect x:Key="CardShadow" Color="#90000000" BlurRadius="20" ShadowDepth="0" Opacity="0.45"/>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Glass}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="Padding" Value="22"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#00000000"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="16">
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#4A17243D"/>
                                <Setter TargetName="Bg" Property="BorderBrush" Value="#88658ECF"/>
                                <Setter Property="Foreground" Value="#DDE8FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PillBtn" TargetType="Button">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="999">
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bg" Property="Opacity" Value="0.9"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="Bg" Property="Opacity" Value="0.75"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="Bg" Property="Opacity" Value="0.45"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryBtn" TargetType="Button" BasedOn="{StaticResource PillBtn}">
            <Setter Property="Background" Value="#E03D7FFF"/><Setter Property="BorderBrush" Value="#FF6A9BFF"/><Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="SmallBtn" TargetType="Button" BasedOn="{StaticResource PillBtn}">
            <Setter Property="FontSize" Value="12"/><Setter Property="Padding" Value="14,7"/>
            <Setter Property="Background" Value="#61172843"/><Setter Property="BorderBrush" Value="#7B638DD1"/><Setter Property="Foreground" Value="#DDE8FF"/>
        </Style>
        <Style x:Key="GhostBtn" TargetType="Button" BasedOn="{StaticResource PillBtn}">
            <Setter Property="Background" Value="#701A2C48"/><Setter Property="BorderBrush" Value="#7C6287C8"/><Setter Property="Foreground" Value="#D9E5FF"/>
        </Style>
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource PillBtn}">
            <Setter Property="Background" Value="#992A1020"/><Setter Property="BorderBrush" Value="#CCB84463"/><Setter Property="Foreground" Value="#FFD5DE"/>
        </Style>

        <Style x:Key="DGHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#75122034"/><Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize" Value="10.5"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Padding" Value="16,12"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/><Setter Property="BorderBrush" Value="#5E3B527A"/>
        </Style>
        <Style x:Key="DGCell" TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="#ECF0FA"/>
            <Setter Property="BorderThickness" Value="0"/><Setter Property="FontSize" Value="13"/><Setter Property="Padding" Value="4,2"/>
            <Style.Triggers><Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#7C24457A"/><Setter Property="Foreground" Value="#E6F0FF"/></Trigger></Style.Triggers>
        </Style>
        <Style x:Key="DGRow" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#63203657"/></Trigger>
                <Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#7C24457A"/></Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LedgerList" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/><Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Cascadia Code, Consolas"/><Setter Property="FontSize" Value="12"/><Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        </Style>
        <Style x:Key="LedgerItem" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/><Setter Property="Padding" Value="16,10"/><Setter Property="BorderThickness" Value="0"/><Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#5A1A2D4A"/></Trigger></Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BgRoot}">
        <Grid Margin="20">
            <Grid.ColumnDefinitions><ColumnDefinition Width="260"/><ColumnDefinition Width="18"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="18" Background="#B9121B2D">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,2,0,24">
                        <TextBlock Text="Transparency" FontSize="22" FontWeight="SemiBold" Foreground="#DCE7FF"/>
                        <TextBlock Text="Network Intelligence Console" FontSize="11.5" Foreground="{StaticResource TextMuted}" Margin="0,6,0,0"/>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="VIEWS" Style="{StaticResource SectionLabel}" Margin="12,0,0,10"/>
                        <Button Name="NavDashboard" Tag="Dashboard" Click="Nav_Click" Style="{StaticResource NavBtn}"><StackPanel Orientation="Horizontal"><TextBlock Text="[ ]" FontFamily="Cascadia Code, Consolas" Margin="0,0,10,0"/><TextBlock Text="Dashboard"/></StackPanel></Button>
                        <Button Name="NavAnomalies" Tag="Anomalies" Click="Nav_Click" Style="{StaticResource NavBtn}"><StackPanel Orientation="Horizontal"><TextBlock Text=" ! " FontFamily="Cascadia Code, Consolas" Margin="0,0,10,0"/><TextBlock Text="Anomalies"/></StackPanel></Button>
                        <Button Name="NavLedger" Tag="Ledger" Click="Nav_Click" Style="{StaticResource NavBtn}"><StackPanel Orientation="Horizontal"><TextBlock Text=" # " FontFamily="Cascadia Code, Consolas" Margin="0,0,10,0"/><TextBlock Text="Activity Ledger"/></StackPanel></Button>
                        <Button Name="NavSettings" Tag="Settings" Click="Nav_Click" Style="{StaticResource NavBtn}"><StackPanel Orientation="Horizontal"><TextBlock Text=" * " FontFamily="Cascadia Code, Consolas" Margin="0,0,10,0"/><TextBlock Text="Privacy Settings"/></StackPanel></Button>
                    </StackPanel>
                    <Border DockPanel.Dock="Bottom" Style="{StaticResource Card}" Background="#7116243D" Padding="14" Margin="0,18,0,0">
                        <StackPanel>
                            <TextBlock Text="Live Posture" Style="{StaticResource SectionLabel}" Margin="0,0,0,10"/>
                            <TextBlock Name="TxtSidebarPosture" Text="Awaiting scan" FontSize="14" FontWeight="SemiBold" Foreground="#DCE7FF"/>
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0"><Ellipse Width="8" Height="8" Fill="{StaticResource Success}" VerticalAlignment="Center" Margin="0,0,7,0"/><TextBlock Text="Sensor online" FontSize="11" Foreground="{StaticResource TextSecondary}"/></StackPanel>
                            <TextBlock Text="v3.7.0 native" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,8,0,0" FontFamily="Cascadia Code, Consolas"/>
                        </StackPanel>
                    </Border>
                </DockPanel>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="14"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <Border Grid.Row="0" Style="{StaticResource Card}" Background="#97152339" Padding="22,18">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Mission Control" FontSize="22" FontWeight="SemiBold"/>
                            <TextBlock Name="TxtTriageSummary" Text="Run a scan to generate an adaptive triage plan." FontSize="12.5" Foreground="{StaticResource TextSecondary}" Margin="0,6,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="Auto Triage" Click="AutoTriage_Click" Style="{StaticResource GhostBtn}" Margin="0,0,10,0"/>
                            <Button Content="Delete Cloud Data" Click="DeleteData_Click" Style="{StaticResource DangerBtn}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="2">
                    <Grid Name="ViewDashboard" Visibility="Visible">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <Border Grid.Row="0" Style="{StaticResource Card}" Background="#9917243B" Padding="24,20" Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel><TextBlock Text="Network Dashboard" FontSize="24" FontWeight="SemiBold"/><TextBlock Name="TxtLastScanned" Text="Run a scan to discover devices on your network." FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,6,0,0"/></StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"><TextBlock Name="TxtScanStatus" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,14,0" VerticalAlignment="Center" FontFamily="Cascadia Code, Consolas"/><Button Name="ScanBtn" Content="Run Scan" Click="Scan_Click" Style="{StaticResource PrimaryBtn}" Margin="0,0,10,0"/><Button Content="Auto Triage" Click="AutoTriage_Click" Style="{StaticResource GhostBtn}"/></StackPanel>
                            </Grid>
                        </Border>
                        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,14">
                            <Border Style="{StaticResource Card}" Background="#9D18253F" Margin="0,0,9,0"><StackPanel><TextBlock Text="TOTAL DEVICES" Style="{StaticResource SectionLabel}"/><TextBlock Name="TxtTotalDevices" Text="-" FontSize="42" FontWeight="SemiBold" Foreground="{StaticResource Accent}"/><TextBlock Text="discovered in latest pass" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,6,0,0"/></StackPanel></Border>
                            <Border Style="{StaticResource Card}" Background="#9C231A30" Margin="3,0,6,0"><StackPanel><TextBlock Text="ACTIVE THREATS" Style="{StaticResource SectionLabel}"/><TextBlock Name="TxtActiveThreats" Text="-" FontSize="42" FontWeight="SemiBold" Foreground="{StaticResource Danger}"/><TextBlock Text="high, medium, or low anomalies" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,6,0,0"/></StackPanel></Border>
                            <Border Style="{StaticResource Card}" Background="#9220342C" Margin="6,0,3,0"><StackPanel><TextBlock Text="CLOUD SYNCS" Style="{StaticResource SectionLabel}"/><TextBlock Name="TxtCloudSyncs" Text="-" FontSize="42" FontWeight="SemiBold" Foreground="{StaticResource Success}"/><TextBlock Text="enrichment actions logged" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,6,0,0"/></StackPanel></Border>
                            <Border Style="{StaticResource Card}" Background="#9A16263F" Margin="9,0,0,0"><StackPanel><TextBlock Text="POSTURE SCORE" Style="{StaticResource SectionLabel}"/><TextBlock Name="TxtPostureScore" Text="100" FontSize="42" FontWeight="SemiBold" Foreground="#BBD5FF"/><TextBlock Text="dynamic score after each scan" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,6,0,0"/></StackPanel></Border>
                        </UniformGrid>
                        <Border Grid.Row="2" Style="{StaticResource Card}" Background="#8716263F" Margin="0,0,0,12" Padding="20,14">
                            <DockPanel LastChildFill="False"><TextBlock Text="DISCOVERED DEVICES" Style="{StaticResource SectionLabel}" Margin="0,0,0,0"/><StackPanel Orientation="Horizontal" DockPanel.Dock="Right"><Button Content="Auto Triage" Click="AutoTriage_Click" Style="{StaticResource SmallBtn}"/></StackPanel></DockPanel>
                        </Border>
                        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="0" Background="#7D131D30">
                            <DataGrid Name="DeviceGrid" AutoGenerateColumns="False" Background="Transparent" BorderThickness="0" RowBackground="Transparent" AlternatingRowBackground="#2A12213B" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#3D30496E" IsReadOnly="True" SelectionMode="Single" HeadersVisibility="Column" ColumnHeaderStyle="{StaticResource DGHeader}" CellStyle="{StaticResource DGCell}" RowStyle="{StaticResource DGRow}" RowHeaderWidth="0" CanUserResizeRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="IP ADDRESS" Binding="{Binding IpAddress}" Width="130"/>
                                    <DataGridTextColumn Header="HOSTNAME" Binding="{Binding DisplayName}" Width="*"/>
                                    <DataGridTextColumn Header="MAC ADDRESS" Binding="{Binding MacAddress}" Width="170"/>
                                    <DataGridTextColumn Header="OPEN PORTS" Binding="{Binding OpenPortsDisplay}" Width="*"/>
                                    <DataGridTemplateColumn Header="ACTION" Width="100"><DataGridTemplateColumn.CellTemplate><DataTemplate><Button Content="Enrich" Click="Enrich_Click" Style="{StaticResource SmallBtn}" Margin="6,4"/></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>

                    <Grid Name="ViewAnomalies" Visibility="Collapsed">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <Border Grid.Row="0" Style="{StaticResource Card}" Background="#951A2038" Padding="24,18" Margin="0,0,0,14">
                            <DockPanel LastChildFill="False"><StackPanel><TextBlock Text="Security Anomalies" FontSize="24" FontWeight="SemiBold"/><TextBlock Text="Detection cards include explanation, remediation, and evidence trace." FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,5,0,0"/></StackPanel><StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center"><TextBlock Name="TxtAnomalyCount" FontSize="12" Foreground="{StaticResource TextSecondary}" FontFamily="Cascadia Code, Consolas" Margin="0,0,14,0"/><Button Content="Auto Triage" Click="AutoTriage_Click" Style="{StaticResource SmallBtn}"/></StackPanel></DockPanel>
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Border Name="AnomalyEmptyState" Style="{StaticResource Card}" Padding="34" Margin="0,0,0,10" Background="#7A162236"><TextBlock Text="No anomalies detected. Run a scan first." Foreground="{StaticResource TextSecondary}" FontSize="14" HorizontalAlignment="Center"/></Border>
                                <ItemsControl Name="AnomaliesList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,12" CornerRadius="18" BorderThickness="1" Background="#88162338" BorderBrush="#60324D7A">
                                                <StackPanel>
                                                    <Grid Margin="20,18,20,12"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                        <Border Grid.Column="0" Width="48" Height="48" CornerRadius="24" Margin="0,0,16,0" VerticalAlignment="Top">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#102C1F"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Severity}" Value="High">
                                                                            <Setter Property="Background" Value="#3C1420"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Severity}" Value="Medium">
                                                                            <Setter Property="Background" Value="#3B2A11"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" FontFamily="Cascadia Code, Consolas">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Text" Value="L"/>
                                                                        <Setter Property="Foreground" Value="#2FD191"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Severity}" Value="High">
                                                                                <Setter Property="Text" Value="H"/>
                                                                                <Setter Property="Foreground" Value="#FF607A"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Severity}" Value="Medium">
                                                                                <Setter Property="Text" Value="M"/>
                                                                                <Setter Property="Foreground" Value="#FFB547"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>
                                                        <StackPanel Grid.Column="1"><TextBlock Text="{Binding Type}" FontWeight="SemiBold" FontSize="14.5"/><TextBlock Text="{Binding DeviceIp}" Foreground="{StaticResource Accent}" FontFamily="Cascadia Code, Consolas" FontSize="12" Margin="0,4,0,6"/><TextBlock Text="{Binding Description}" Foreground="{StaticResource TextSecondary}" FontSize="13" TextWrapping="Wrap"/></StackPanel>
                                                    </Grid>
                                                    <Expander Margin="20,0,20,18">
                                                        <Expander.Header><TextBlock Text="Details - Explanation, Remediation and Trace" FontSize="12" Foreground="{StaticResource TextMuted}"/></Expander.Header>
                                                        <Border Background="#7B121A2C" CornerRadius="12" Padding="20,16" Margin="0,8,0,0" BorderThickness="1" BorderBrush="#67415D8B">
                                                            <StackPanel>
                                                                <TextBlock Text="WHY THIS MATTERS" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource Accent}" Margin="0,0,0,6" FontFamily="Cascadia Code, Consolas"/>
                                                                <TextBlock Text="{Binding Explanation}" Foreground="{StaticResource TextSecondary}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,16"/>
                                                                <TextBlock Text="RECOMMENDED REMEDIATION" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource Success}" Margin="0,0,0,6" FontFamily="Cascadia Code, Consolas"/>
                                                                <TextBlock Text="{Binding Remediation}" Foreground="{StaticResource TextSecondary}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,16"/>
                                                                <TextBlock Text="DETECTION TRACE" FontSize="10" FontWeight="SemiBold" Foreground="#FFB547" Margin="0,0,0,6" FontFamily="Cascadia Code, Consolas"/>
                                                                <Border Background="#86101828" CornerRadius="8" Padding="12,10" Margin="0,0,0,12"><TextBlock Text="{Binding TraceSource}" Foreground="{StaticResource TextSecondary}" FontFamily="Cascadia Code, Consolas" FontSize="12" TextWrapping="Wrap"/></Border>
                                                                <TextBlock Text="AFFECTED PORTS" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" Margin="0,0,0,6" FontFamily="Cascadia Code, Consolas"/>
                                                                <TextBlock Text="{Binding AffectedPortsDisplay}" Foreground="{StaticResource TextSecondary}" FontFamily="Cascadia Code, Consolas" FontSize="12"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </Expander>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <Grid Name="ViewLedger" Visibility="Collapsed">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <Border Grid.Row="0" Style="{StaticResource Card}" Background="#90142239" Padding="24,18" Margin="0,0,0,14"><StackPanel><TextBlock Text="Cloud Data Ledger" FontSize="24" FontWeight="SemiBold"/><TextBlock Text="Every enrich or purge operation is appended here for auditable traceability." FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,5,0,0"/></StackPanel></Border>
                        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0" Background="#7A131C2E"><ScrollViewer VerticalScrollBarVisibility="Auto"><ListBox Name="LedgerList" Style="{StaticResource LedgerList}" ItemContainerStyle="{StaticResource LedgerItem}"/></ScrollViewer></Border>
                    </Grid>

                    <Grid Name="ViewSettings" Visibility="Collapsed">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <Border Grid.Row="0" Style="{StaticResource Card}" Background="#9418243C" Padding="24,18" Margin="0,0,0,14"><StackPanel><TextBlock Text="Privacy and Settings" FontSize="24" FontWeight="SemiBold"/><TextBlock Text="Transparency is local-first: scans stay on-device unless you request enrichment." FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,5,0,0"/></StackPanel></Border>
                        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,14" Background="#7F1A2439"><StackPanel><TextBlock Text="HOW YOUR DATA IS USED" Style="{StaticResource SectionLabel}"/><TextBlock FontSize="13" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" LineHeight="22">Transparency scans your local network with ICMP probes and TCP checks. Scan data stays local by default. Clicking Enrich sends limited metadata to this app's local mock cloud service. You can purge that history instantly.</TextBlock></StackPanel></Border>
                        <Border Grid.Row="2" Style="{StaticResource Card}" Background="#7F211A32"><StackPanel><TextBlock Text="DATA CONTROLS" Style="{StaticResource SectionLabel}"/><TextBlock Text="Remove all cloud-side records at any time." FontSize="13" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,18"/><StackPanel Orientation="Horizontal"><Button Content="Delete All Cloud Data" Click="DeleteData_Click" Style="{StaticResource DangerBtn}"/></StackPanel></StackPanel></Border>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <Border Name="LoadingOverlay" Grid.ColumnSpan="2" Background="#B8050A14" Visibility="Collapsed">
            <Border Style="{StaticResource Card}" Width="420" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="24" Background="#BE172540">
                <StackPanel>
                    <TextBlock Name="TxtLoadingMsg" Text="Scanning..." FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource Accent}" HorizontalAlignment="Center"/>
                    <TextBlock Name="TxtLoadingDetail" Text="" FontSize="12" Foreground="{StaticResource TextSecondary}" FontFamily="Cascadia Code, Consolas" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
