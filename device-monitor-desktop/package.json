{
  "name": "device-monitor-desktop",
  "version": "4.4.0",
  "description": "Desktop application for comprehensive device security monitoring and threat detection",
  "main": "main.js",
  "homepage": "https://github.com/MantheD27/transparency",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "chart.js": "^4.0.0",
    "express": "^4.22.1"
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "latest",
    "proxyquire": "^2.1.3"
  },
  "author": "Security Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MantheDan27/transparency.git"
  },
  "build": {
    "appId": "com.devicemonitor.app",
    "productName": "Device Monitor Desktop",
    "publish": null,
    "files": [
      "main.js",
      "preload.js",
      "scanner.js",
      "cloud-mock.js",
      "src/**",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "icon": "assets/icon.png",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "snap"
      ]
    }
  }
}
