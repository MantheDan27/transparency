{
    "version": "2.0.0",
    "tasks": [
        // ============================================
        // CMake Configuration Tasks
        // ============================================
        {
            "label": "CMake: Configure Debug",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-B", "build",
                "-S", ".",
                "-DCMAKE_BUILD_TYPE=Debug",
                "-G", "Visual Studio 17 2022",
                "-A", "x64"
            ],
            "options": {
                "cwd": "${workspaceFolder}/transparency-cpp"
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "CMake: Configure Release",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-B", "build",
                "-S", ".",
                "-DCMAKE_BUILD_TYPE=Release",
                "-G", "Visual Studio 17 2022",
                "-A", "x64"
            ],
            "options": {
                "cwd": "${workspaceFolder}/transparency-cpp"
            },
            "group": "build",
            "problemMatcher": []
        },
        // ============================================
        // CMake Build Tasks
        // ============================================
        {
            "label": "CMake: Build Debug",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "build",
                "--config", "Debug"
            ],
            "options": {
                "cwd": "${workspaceFolder}/transparency-cpp"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile",
            "dependsOn": "CMake: Configure Debug"
        },
        {
            "label": "CMake: Build Release",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "build",
                "--config", "Release"
            ],
            "options": {
                "cwd": "${workspaceFolder}/transparency-cpp"
            },
            "group": "build",
            "problemMatcher": "$msCompile",
            "dependsOn": "CMake: Configure Release"
        },
        {
            "label": "CMake: Clean",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "build",
                "--target", "clean"
            ],
            "options": {
                "cwd": "${workspaceFolder}/transparency-cpp"
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "CMake: Rebuild Debug",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "build",
                "--config", "Debug",
                "--clean-first"
            ],
            "options": {
                "cwd": "${workspaceFolder}/transparency-cpp"
            },
            "group": "build",
            "problemMatcher": "$msCompile",
            "dependsOn": "CMake: Configure Debug"
        },
        // ============================================
        // C++ Test Tasks
        // ============================================
        {
            "label": "Run C++ Tests",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--test-dir", "build",
                "-C", "Debug",
                "--output-on-failure"
            ],
            "options": {
                "cwd": "${workspaceFolder}/transparency-cpp"
            },
            "group": "test",
            "problemMatcher": [],
            "dependsOn": "CMake: Build Debug"
        },
        // ============================================
        // .NET / C# Tasks
        // ============================================
        {
            "label": "dotnet: build TransparencyApp",
            "type": "shell",
            "command": "dotnet",
            "args": [
                "build",
                "${workspaceFolder}/transparency-native/TransparencyApp/TransparencyApp.csproj",
                "-c", "Debug"
            ],
            "group": "build",
            "problemMatcher": "$msCompile"
        },
        {
            "label": "dotnet: run TransparencyApp",
            "type": "shell",
            "command": "dotnet",
            "args": [
                "run",
                "--project", "${workspaceFolder}/transparency-native/TransparencyApp/TransparencyApp.csproj"
            ],
            "group": "build",
            "problemMatcher": "$msCompile"
        },
        {
            "label": "dotnet: test TransparencyApp",
            "type": "shell",
            "command": "dotnet",
            "args": [
                "test",
                "${workspaceFolder}/transparency-native/TransparencyApp.Tests/TransparencyApp.Tests.csproj"
            ],
            "group": "test",
            "problemMatcher": "$msCompile"
        },
        // ============================================
        // Electron Tasks
        // ============================================
        {
            "label": "Electron: npm install",
            "type": "shell",
            "command": "npm",
            "args": ["install"],
            "options": {
                "cwd": "${workspaceFolder}/device-monitor-desktop"
            },
            "problemMatcher": []
        },
        {
            "label": "Electron: Start",
            "type": "shell",
            "command": "npm",
            "args": ["start"],
            "options": {
                "cwd": "${workspaceFolder}/device-monitor-desktop"
            },
            "problemMatcher": []
        },
        {
            "label": "Electron: Start with Debug",
            "type": "shell",
            "command": "npm",
            "args": ["start", "--", "--remote-debugging-port=9222"],
            "options": {
                "cwd": "${workspaceFolder}/device-monitor-desktop"
            },
            "problemMatcher": []
        }
    ]
}
