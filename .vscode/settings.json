{
    // CMake Settings
    "cmake.sourceDirectory": "${workspaceFolder}/transparency-cpp",
    "cmake.buildDirectory": "${workspaceFolder}/transparency-cpp/build",
    "cmake.configureOnOpen": true,
    "cmake.generator": "Visual Studio 17 2022",

    // C/C++ Settings
    "C_Cpp.default.configurationProvider": "ms-vscode.cmake-tools",
    "C_Cpp.default.cppStandard": "c++17",
    "C_Cpp.default.compileCommands": "${workspaceFolder}/transparency-cpp/build/compile_commands.json",

    // .NET / C# Settings
    "dotnet.defaultSolution": "${workspaceFolder}/transparency.sln",

    // File Associations
    "files.associations": {
        "*.h": "cpp",
        "*.cpp": "cpp",
        "*.xaml": "xml"
    },

    // Editor Settings for this project
    "editor.formatOnSave": true,
    "[cpp]": {
        "editor.defaultFormatter": "ms-vscode.cpptools"
    },
    "[csharp]": {
        "editor.defaultFormatter": "ms-dotnettools.csharp"
    }
}
